  "viewBox": {
    "width": 1280,
    "height": 720
  },
  "fonts": {
    "sans": "'PingFang SC', 'Microsoft YaHei', 'SF Pro Display', 'Inter', sans-serif",
    "mono": "'SF Mono', 'JetBrains Mono', Menlo, monospace",
    "display": "'PingFang SC', 'Microsoft YaHei', 'SF Pro Display', 'Inter', sans-serif"
  },
  "type_scale": {
    "eyebrow": 16,
    "h1": 60,
    "h2": 44,
    "h3": 30,
    "h4": 22,
    "body": 18,
    "small": 14,
    "stat_huge": 110,
    "stat_unit": 28
