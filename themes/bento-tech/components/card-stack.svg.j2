{# card-stack: 多数据叠加卡（一张卡承载一组相关指标）
   原版参考：AIoT 卡 = 大数字 8.6亿+ + 两小数字 + 进度条 + 描述
   data:
     label    string?   顶部小字（数据组的标题）
     primary  object    主数字 {value, unit?, suffix?}
     secondary array?   2-3 个支撑指标 [{label, value}]，横向铺
     progress  object?  {percent: 0-100, label?: string}  底部进度条
     badges    array?   胶囊小标签

   通用布局规则（不只是 H 自适应）：
     画布纵向分三段：
       top    = label + badges 区
       middle = primary + secondary 内容主体（作为整块在剩余空间垂直居中）
       bottom = progress 区
     无论 H 多大，middle 内容总是在 top 与 bottom 之间居中——这样：
       - 大卡 H=580：内容稳居中段，下方 progress 不孤立
       - 小卡 H=200：内容居中后不出现"上挤下空"

   字号 + 间距按 H 三档分；secondary 在 H<180 时跳过；
   再用 fail-safe 检查计算后的 baseline 是否会越界。
#}
{%- from "macros.svg.j2" import render_badges -%}
{%- set d = data -%}
{%- set H = slot_h or 560 -%}
{%- set W = slot_w or 600 -%}

{%- if H >= 360 -%}
{%- set huge = 100 if W >= 600 else (80 if W >= 380 else 64) -%}
{%- set sec_gap = 40 -%}
{%- set sec_label_to_value = 30 -%}
{%- set sec_value_size = theme.type_scale.h3 -%}
{%- elif H >= 240 -%}
{%- set huge = 64 if W >= 380 else 48 -%}
{%- set sec_gap = 22 -%}
{%- set sec_label_to_value = 22 -%}
{%- set sec_value_size = 22 -%}
{%- else -%}
{%- set huge = 48 -%}
{%- set sec_gap = 16 -%}
{%- set sec_label_to_value = 18 -%}
{%- set sec_value_size = 18 -%}
{%- endif -%}

{%- set unit_size = (huge * 0.30) | int -%}
{%- set p = d.primary or {} -%}
{%- set v_str = p.value | default('') | string -%}

{%- set ns = namespace(vw=0) -%}
{%- for ch in v_str -%}
{%- if '\u4e00' <= ch <= '\u9fff' -%}{%- set ns.vw = ns.vw + huge -%}
{%- else -%}{%- set ns.vw = ns.vw + (huge * 0.55) | int -%}{%- endif -%}
{%- endfor -%}

{# === 上段：label + badges === #}
{%- set y = namespace(p=0) -%}

{%- if d.label -%}
{%- set y.p = y.p + theme.type_scale.eyebrow + 4 -%}
<text x="0" y="{{ y.p }}" class="eyebrow">{{ d.label }}</text>
{%- endif -%}

{%- if d.badges -%}
{%- set y.p = y.p + 28 -%}
{{ render_badges(d.badges, 0, y.p - 18, theme) }}
{%- set y.p = y.p + 4 -%}
{%- endif -%}

{%- set top_h = y.p + 8 -%}{# 上段总高（含 8px 与中段 gap）#}

{# === 下段：progress 预留 === #}
{%- if d.progress -%}
{%- set bottom_h = 60 if d.progress.label else 30 -%}
{%- else -%}
{%- set bottom_h = 0 -%}
{%- endif -%}

{# === 中段：primary + secondary
     宽矮卡（H<280 且 W>=520）：secondary 横向铺在 primary 右侧（节省垂直空间）
     其他卡：secondary 在 primary 下方居中排列
     用 visual top/bottom 而非 baseline 算 content_h，保证视觉居中
=== #}
{%- set has_sec = (d.secondary is defined) and d.secondary and (H >= 180) -%}
{%- set side_by_side = (H < 280) and (W >= 520) and has_sec -%}
{%- set primary_visual_h = (huge * 0.85) | int -%}

{%- if side_by_side -%}
{# 横向模式：primary 占左半，secondary 占右半
   primary baseline 居中在 mid 段（无 secondary 块计入高度）#}
{%- set content_visual_h = primary_visual_h -%}
{%- set mid_avail = H - top_h - bottom_h -%}
{%- set mid_pad = ((mid_avail - content_visual_h) / 2) | int -%}
{%- if mid_pad < 0 -%}{%- set mid_pad = 0 -%}{%- endif -%}
{%- set primary_y = top_h + mid_pad + primary_visual_h -%}
{%- else -%}
{%- if has_sec -%}
{%- set sec_visual_tail = (sec_value_size * 0.2) | int -%}
{%- set sec_block_h = sec_gap + sec_label_to_value + sec_visual_tail -%}
{%- else -%}
{%- set sec_block_h = 0 -%}
{%- endif -%}
{%- set content_visual_h = primary_visual_h + sec_block_h -%}
{%- set mid_avail = H - top_h - bottom_h -%}
{%- set mid_pad = ((mid_avail - content_visual_h) / 2) | int -%}
{%- if mid_pad < 0 -%}{%- set mid_pad = 0 -%}{%- endif -%}
{%- set primary_y = top_h + mid_pad + primary_visual_h -%}
{%- endif -%}

{%- if p.value -%}
<text x="0" y="{{ primary_y }}" font-size="{{ huge }}" fill="{{ theme.colors.text_primary }}" font-weight="800" font-family="{{ theme.fonts.display }}">{{ v_str }}</text>
{%- if p.unit -%}
<text x="{{ ns.vw + 8 }}" y="{{ primary_y }}" font-size="{{ unit_size }}" fill="{{ theme.colors.accent_secondary }}" font-weight="600">{{ p.unit }}</text>
{%- endif -%}
{%- if p.suffix -%}
{%- set unit_w_est = ((p.unit | default('') | length) * unit_size * 0.6) | int -%}
<text x="{{ ns.vw + 8 + unit_w_est + (12 if p.unit else 0) }}" y="{{ primary_y - 4 }}" font-size="{{ theme.type_scale.body }}" fill="{{ theme.colors.text_secondary }}">{{ p.suffix }}</text>
{%- endif -%}
{%- endif -%}

{%- if has_sec -%}
{%- set sec = d.secondary[:3] -%}
{%- if side_by_side -%}
{# 横向模式：primary 占左半（按 value width + suffix + 80px gap），secondary 在右侧均分
   sec 区起始 x = max(主数字宽 + suffix 估算 + 一些 padding, W*0.5) #}
{%- set p_unit_w = ((p.unit | default('') | length) * unit_size * 0.6) | int -%}
{%- set p_suffix_w = ((p.suffix | default('') | length) * theme.type_scale.body * 0.55) | int -%}
{%- set primary_block_w = ns.vw + 8 + p_unit_w + 12 + p_suffix_w + 24 -%}
{%- if primary_block_w < (W * 0.5) | int -%}{%- set primary_block_w = (W * 0.5) | int -%}{%- endif -%}
{%- set sec_area_w = W - primary_block_w -%}
{%- set sec_col_w = (sec_area_w / (sec | length)) | int -%}
{%- set sec_label_y_h = primary_y - (primary_visual_h * 0.5) | int -%}
{%- set sec_value_y_h = sec_label_y_h + sec_label_to_value -%}
{%- for s in sec -%}
{%- set sx = primary_block_w + loop.index0 * sec_col_w -%}
<text x="{{ sx }}" y="{{ sec_label_y_h }}" font-size="12" fill="{{ theme.colors.text_muted }}" letter-spacing="1">{{ s.label }}</text>
<text x="{{ sx }}" y="{{ sec_value_y_h }}" font-size="{{ sec_value_size }}" fill="{{ theme.colors.text_primary }}" font-weight="700">{{ s.value }}</text>
{%- endfor -%}
{%- else -%}
{# 竖向模式：secondary 在 primary 下方居中排列（原逻辑）#}
{%- set col_w = (W / (sec | length)) | int -%}
{%- set sec_label_y = primary_y + sec_gap -%}
{%- set sec_value_y = sec_label_y + sec_label_to_value -%}
{%- if sec_value_y < H - bottom_h - 2 -%}
{%- for s in sec -%}
{%- set sx = loop.index0 * col_w -%}
<text x="{{ sx }}" y="{{ sec_label_y }}" font-size="12" fill="{{ theme.colors.text_muted }}" letter-spacing="1">{{ s.label }}</text>
<text x="{{ sx }}" y="{{ sec_value_y }}" font-size="{{ sec_value_size }}" fill="{{ theme.colors.text_primary }}" font-weight="700">{{ s.value }}</text>
{%- endfor -%}
{%- endif -%}
{%- endif -%}
{%- endif -%}

{%- if d.progress -%}
{%- set pct = d.progress.percent | default(0) | int -%}
{%- if pct < 0 -%}{%- set pct = 0 -%}{%- endif -%}
{%- if pct > 100 -%}{%- set pct = 100 -%}{%- endif -%}
{%- set bar_y = H - bottom_h -%}
<rect x="0" y="{{ bar_y }}" width="{{ W }}" height="6" rx="3" fill="{{ theme.colors.card_fill }}" fill-opacity="0.10"/>
<rect x="0" y="{{ bar_y }}" width="{{ ((W * pct) / 100) | int }}" height="6" rx="3" fill="url(#accent-grad)"/>
{%- if d.progress.label -%}
<text x="0" y="{{ bar_y + 28 }}" font-size="{{ theme.type_scale.small }}" fill="{{ theme.colors.text_secondary }}">{{ d.progress.label }}</text>
{%- endif -%}
{%- endif -%}