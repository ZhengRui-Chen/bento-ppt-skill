{# card-list: 标题 + 多条要点（带序号方块）
   data:
     eyebrow string?
     title   string?
     accent  string?  序号方块色调：'success'|'warning'|'default'
     items   array of {title, desc?, highlight?: bool} | array of strings
       highlight: true 的项 — 序号方块实色 + 标题加亮 + 左侧主题色细线
       未 highlight 的项 — 标题降亮（text_secondary）让重点更突出
       注：如果**没有任何 item 带 highlight**，所有项视觉一致（不降亮）
#}
{%- set d = data -%}
{%- set H = slot_h or 560 -%}
{%- set W = slot_w or 600 -%}
{%- set items_in = d['items'] or [] -%}

{%- set accent = d.accent | default('default') -%}
{%- set is_light = theme.colors.bg_start[:3] == '#F' -%}
{%- if accent == 'success' -%}
{%- set badge_fill = theme.colors.accent_success -%}
{%- set badge_text = '#ffffff' if is_light else '#0a3a1f' -%}
{%- elif accent == 'warning' -%}
{%- set badge_fill = theme.colors.accent_warning -%}
{%- set badge_text = '#ffffff' if is_light else '#3a2308' -%}
{%- else -%}
{%- set badge_fill = 'url(#accent-grad)' -%}
{%- set badge_text = '#ffffff' if is_light else '#0a0e27' -%}
{%- endif -%}

{# 是否启用降亮模式：只要有任何 item 带 highlight=true #}
{%- set ns_h = namespace(any=false) -%}
{%- for it in items_in -%}
{%- if it is mapping and it.highlight -%}{%- set ns_h.any = true -%}{%- endif -%}
{%- endfor -%}
{%- set dim_others = ns_h.any -%}

{%- set y = namespace(p=0) -%}

{%- if d.eyebrow -%}
{%- set y.p = y.p + theme.type_scale.eyebrow + 4 -%}
<text x="0" y="{{ y.p }}" class="eyebrow">{{ d.eyebrow }}</text>
{%- endif -%}

{%- if d.title -%}
{%- set y.p = y.p + theme.type_scale.h3 + 18 -%}
<text x="0" y="{{ y.p }}" class="h3">{{ d.title }}</text>
{%- set y.p = y.p + 16 -%}
{%- endif -%}

{%- if not d.eyebrow and not d.title -%}{%- set y.p = 8 -%}{%- endif -%}
{%- set list_top = y.p + 12 -%}

{%- set has_desc = items_in | selectattr('desc', 'defined') | list | length > 0 -%}
{%- set min_row = 44 if has_desc else 32 -%}
{%- set avail_h = H - list_top - 16 -%}
{%- set max_fit = (avail_h / min_row) | int -%}
{%- if max_fit < 1 -%}{%- set max_fit = 1 -%}{%- endif -%}
{# 截断策略：优先保留 highlight 项，剩余按原顺序填补 #}
{%- if (items_in | length) <= max_fit -%}
{%- set items_use = items_in -%}
{%- else -%}
{%- set ns_sel = namespace(idx=[]) -%}
{%- for it in items_in -%}
{%- if (it is mapping) and it.highlight and (ns_sel.idx | length) < max_fit -%}
{%- set _ = ns_sel.idx.append(loop.index0) -%}
{%- endif -%}
{%- endfor -%}
{%- for it in items_in -%}
{%- if (loop.index0 not in ns_sel.idx) and (ns_sel.idx | length) < max_fit -%}
{%- set _ = ns_sel.idx.append(loop.index0) -%}
{%- endif -%}
{%- endfor -%}
{%- set items_use = ns_sel.idx | sort | map('extract', items_in) | list -%}
{%- endif -%}
{%- set n = items_use | length -%}

{%- set row_h = (avail_h / n) | int -%}
{%- if row_h < min_row -%}{%- set row_h = min_row -%}{%- endif -%}
{%- if row_h > 80 -%}{%- set row_h = 80 -%}{%- endif -%}

{%- for it in items_use -%}
{%- set ry = list_top + loop.index0 * row_h -%}
{%- if it is string -%}
{%- set it_title = it -%}
{%- set it_desc = none -%}
{%- set is_hl = false -%}
{%- else -%}
{%- set it_title = it.title -%}
{%- set it_desc = it.desc -%}
{%- set is_hl = it.highlight | default(false) -%}
{%- endif -%}
{# 颜色策略：dim_others 模式下，非高亮项降亮 #}
{%- set this_fill = badge_fill -%}
{%- set this_op = '1.0' -%}
{%- set title_fill = theme.colors.text_primary -%}
{%- set desc_fill = theme.colors.text_secondary -%}
{%- if dim_others and not is_hl -%}
{%- set this_op = '0.42' -%}
{%- set title_fill = theme.colors.text_secondary -%}
{%- set desc_fill = theme.colors.text_muted -%}
{%- endif -%}
<g transform="translate(0, {{ ry }})" opacity="{{ this_op }}">
  {%- if is_hl %}
  {# 高亮项视觉强化：左侧 4px 主题色粗条，对齐"内容区"高度（不含 row 间的 gap）#}
  {%- set bar_h = 50 if it_desc else 32 -%}
  <rect x="-12" y="0" width="4" height="{{ bar_h }}" rx="2" fill="{{ badge_fill }}"/>
  {%- endif %}
  <rect x="0" y="0" width="32" height="32" rx="8" fill="{{ badge_fill }}"/>
  <text x="16" y="22" text-anchor="middle" font-size="15" font-weight="700" fill="{{ badge_text }}">{{ '%02d' | format(loop.index) }}</text>
  <text x="48" y="22" font-size="18" fill="{{ title_fill }}" font-weight="{{ '700' if is_hl else '600' }}">{{ it_title }}</text>
  {%- if it_desc %}
  <text x="48" y="46" font-size="14" fill="{{ desc_fill }}">{{ it_desc }}</text>
  {%- endif %}
</g>
{%- endfor -%}