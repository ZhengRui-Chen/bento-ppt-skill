{
  "name": "bento-ink",
  "version": "1.0.0",
  "description": "水墨克制美学 — 极简色彩 · 纸墨质感 · 让文字成为视觉焦点",
  "viewBox": {
    "width": 1280,
    "height": 720
  },
  "fonts": {
    "sans": "'PingFang SC', 'Noto Sans SC', 'Microsoft YaHei', sans-serif",
    "mono": "'IBM Plex Mono', 'SF Mono', 'JetBrains Mono', Menlo, monospace",
    "display": "'Songti SC', 'Noto Serif SC', 'STKaiti', 'Times New Roman', serif"
  },
  "type_scale": {
    "eyebrow": 13,
    "h1": 54,
    "h2": 40,
    "h3": 26,
    "h4": 19,
    "body": 16,
    "small": 12,
    "stat_huge": 96,
    "stat_unit": 24
  },
  "colors": {
    "bg_start": "#f4f1ea",
    "bg_end": "#ece8df",
    "card_fill": "#FFFFFF",
    "card_fill_opacity": 0.90,
    "card_stroke": "#111110",
    "card_stroke_opacity": 0.05,
    "text_primary": "#111110",
    "text_secondary": "#4a4845",
    "text_muted": "#8a8882",
    "accent_primary": "#c44536",
    "accent_secondary": "#8b5742",
    "accent_tertiary": "#b83a2a",
    "accent_success": "#4a6b5d",
    "accent_warning": "#c49b2a"
